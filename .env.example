# OIDC Configuration
# Discovery URL (optional, defaults to https://accounts.appforges.com/.well-known/openid-configuration)
# OIDC_DISCOVERY_URL=https://accounts.appforges.com/.well-known/openid-configuration

# Required: OIDC client credentials
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# Required: Comma-separated whitelist of allowed phone numbers or emails
ALLOWED_USERS=user@example.com,+8613800138000

# Server
PORT=3000
BASE_URL=http://localhost:3000

# Session secret (change in production)
SESSION_SECRET=change-me-to-a-random-string
