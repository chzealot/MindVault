# OIDC 配置
# 发现端点 URL（可选，默认为 https://accounts.appforges.com/.well-known/openid-configuration）
# OIDC_DISCOVERY_URL=https://accounts.appforges.com/.well-known/openid-configuration

# 必填：OIDC 客户端凭据
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# 必填：允许访问的用户列表（逗号分隔的邮箱或手机号）
ALLOWED_USERS=user@example.com,+8613800138000

# 服务器配置
PORT=3000
BASE_URL=http://localhost:3000

# Session 加密密钥（生产环境务必修改）
# 生成方式：openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-string
